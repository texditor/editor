{
  "name": "texditor",
  "version": "2.0.6",
  "description": "Texditor is a modern block—based text editor that allows you to export data in JSON format.",
  "license": "MIT",
  "author": "Eduard Y",
  "homepage": "https://texditor.priveted.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/texditor/editor"
  },
  "type": "module",
  "main": "./dist/texditor.mjs",
  "module": "./dist/texditor.mjs",
  "types": "./dist/texditor.d.ts",
  "exports": {
    ".": {
      "import": "./dist/texditor.mjs",
      "types": "./dist/texditor.d.ts"
    },
    "./core/base": {
      "import": "./dist/core/base.mjs",
      "types": "./dist/core/base.d.ts"
    },
    "./core/models": {
      "import": "./dist/core/models.mjs",
      "types": "./dist/core/models.d.ts"
    },
    "./entities/actions": {
      "import": "./dist/entities/actions.mjs",
      "types": "./dist/entities/actions.d.ts"
    },
    "./entities/blocks": {
      "import": "./dist/entities/blocks.mjs",
      "types": "./dist/entities/blocks.d.ts"
    },
    "./entities/blocks/files/actions": {
      "import": "./dist/entities/blocks/files/actions.mjs",
      "types": "./dist/entities/blocks/files/actions.d.ts"
    },
    "./entities/tools": {
      "import": "./dist/entities/tools.mjs",
      "types": "./dist/entities/tools.d.ts"
    },
    "./locales": {
      "import": "./dist/locales.mjs",
      "types": "./dist/locales.d.ts"
    },
    "./entities/extensions": {
      "import": "./dist/entities/extensions.mjs",
      "types": "./dist/entities/extensions.d.ts"
    },
    "./styles/theme.css": "./dist/styles/theme.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "editor",
    "json",
    "html",
    "wysiwyg",
    "blocks",
    "modular",
    "typescript"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vite-plugin-dts": "^5.0.1"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "snappykit": "^1.0.11",
    "sortum": "^1.0.6"
  }
}
