{
  "name": "@texditor/editor",
  "version": "2.0.0",
  "description": "Texditor is a modern, block-based text editor written in TypeScript. It has a clean architecture and an extensible design that allows users to customize the content blocks",
  "type": "module",
  "main": "./dist/texditor.mjs",
  "module": "./dist/texditor.mjs",
  "types": "./dist/texditor.d.ts",
  "exports": {
    ".": {
      "import": "./dist/texditor.mjs",
      "types": "./dist/texditor.d.ts"
    },
    "./core/base": {
      "import": "./dist/core/base.mjs",
      "types": "./dist/core/base.d.ts"
    },
    "./core/models": {
      "import": "./dist/core/models.mjs",
      "types": "./dist/core/models.d.ts"
    },
    "./entities/actions": {
      "import": "./dist/entities/actions.mjs",
      "types": "./dist/entities/actions.d.ts"
    },
    "./entities/blocks": {
      "import": "./dist/entities/blocks.mjs",
      "types": "./dist/entities/blocks.d.ts"
    },
    "./entities/tools": {
      "import": "./dist/entities/tools.mjs",
      "types": "./dist/entities/tools.d.ts"
    },
    "./locales": {
      "import": "./dist/locales.mjs",
      "types": "./dist/locales.d.ts"
    },
    "./entities/extensions": {
      "import": "./dist/entities/extensions.mjs",
      "types": "./dist/entities/extensions.d.ts"
    },
    "./styles/*.css": {
      "default": "./dist/styles/*.css"
    }
  },
  "scripts": {
    "dev": "vite",
    "prepare": "npm run build",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "eslint": "^10.0.1",
    "globals": "^16.3.0",
    "prettier": "^3.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-static-copy": "^3.1.1"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  }
}
