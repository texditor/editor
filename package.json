{
  "name": "@texditor/editor",
  "version": "2.0.0",
  "description": "Texditor is a modern, block-based text editor written in TypeScript. It has a clean architecture and an extensible design that allows users to customize the content blocks",
  "type": "module",
  "main": "./dist/texditor.mjs",
  "module": "./dist/texditor.mjs",
  "types": "./dist/types/texditor.d.ts",
  "exports": {
    ".": {
      "import": "./dist/texditor.mjs",
      "types": "./dist/types/texditor.d.ts"
    },
    "./core/base": {
      "import": "./dist/core/base.mjs",
      "types": "./dist/types/core/base.d.ts"
    },
    "./core/models": {
      "import": "./dist/core/models.mjs",
      "types": "./dist/types/core/models.d.ts"
    },
    "./entities/actions": {
      "import": "./dist/entities/actions.mjs",
      "types": "./dist/types/entities/actions.d.ts"
    },
    "./entities/blocks": {
      "import": "./dist/entities/blocks.mjs",
      "types": "./dist/types/entities/blocks.d.ts"
    },
    "./entities/tools": {
      "import": "./dist/entities/tools.mjs",
      "types": "./dist/types/entities/tools.d.ts"
    },
    "./locales": {
      "import": "./dist/locales.mjs",
      "types": "./dist/types/locales.d.ts"
    },
    "./entities/extensions": {
      "import": "./dist/entities/extensions.mjs",
      "types": "./dist/types/entities/extensions.d.ts"
    },
    "./styles/*.css": {
      "default": "./dist/styles/*.css"
    }
  },
  "scripts": {
    "dev": "vite",
    "prepare": "npm run build",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/sortablejs": "^1.15.9",
    "eslint": "^9.29.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.38.0",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-static-copy": "^3.1.1"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "sortablejs": "^1.15.7"
  }
}